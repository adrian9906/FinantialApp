{
  "name": "plata-app-workspace",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.18.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ],
    "overrides": {
      "babel-preset-expo": "56.0.15"
    }
  },
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "pnpm --dir apps/api dev",
    "dev:mobile": "pnpm --dir apps/mobile start",
    "build:web": "pnpm --dir apps/web build",
    "build:api": "pnpm --dir apps/api build",
    "build:mobile": "pnpm --dir apps/mobile typecheck",
    "lint:web": "pnpm --dir apps/web lint",
    "db:generate": "pnpm --dir apps/api db:generate",
    "db:migrate": "pnpm --dir apps/api db:migrate",
    "db:push": "pnpm --dir apps/api db:push",
    "db:studio": "pnpm --dir apps/api db:studio"
  }
}
