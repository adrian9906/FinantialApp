{
  "name": "@plata/api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx --env-file=.env src/server.ts",
    "build": "prisma generate --config prisma.config.ts --schema prisma/schema.prisma && tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js",
    "db:generate": "prisma generate --config prisma.config.ts --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --config prisma.config.ts --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --config prisma.config.ts --schema prisma/schema.prisma",
    "db:push": "prisma db push --config prisma.config.ts --schema prisma/schema.prisma",
    "db:studio": "prisma studio --config prisma.config.ts --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@plata/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "prisma": "^7.8.0",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2"
  }
}
