generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id         String   @id @default(uuid())
  nombre     String
  correo     String   @unique
  contrasena String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  salarios       Salario[]
  ahorros        Ahorro[]
  gastos         Gasto[]
  gustos         Gusto[]
  deudas         Deuda[]
  eventos        Evento[]
  deseos         Deseo[]
  historiales    HistorialMensual[]
  proyecciones   Proyeccion[]
  metasAhorro    MetaAhorro[]
  notificaciones Notificacion[]
  sesiones       Sesion[]

  @@map("usuarios")
}

model Salario {
  id        String   @id @default(uuid())
  salario   Float
  fecha     DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("salarios")
}

model Ahorro {
  id        String   @id @default(uuid())
  cantidad  Float
  fecha     DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("ahorros")
}

model Gasto {
  id        String   @id @default(uuid())
  cantidad  Float
  fecha     DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  items     Item[]

  @@map("gastos")
}

model Gusto {
  id        String   @id @default(uuid())
  cantidad  Float
  fecha     DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  items     Item[]

  @@map("gustos")
}

model Deuda {
  id               String   @id @default(uuid())
  cantidad         Float
  historial        String
  fechaInicio      DateTime
  fechaTerminacion DateTime
  interes          Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  usuarioId        String
  usuario          Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pagos            DeudaPago[]

  @@map("deudas")
}

model DeudaPago {
  id        String   @id @default(uuid())
  cantidad  Float
  fecha     DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deudaId   String
  deuda     Deuda    @relation(fields: [deudaId], references: [id], onDelete: Cascade)

  @@map("deudas_pagos")
}

model Item {
  id        String   @id @default(uuid())
  nombre    String
  precio    Float
  fecha     DateTime @default(now())
  categoria String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gastoId   String?
  gustoId   String?
  gasto     Gasto?   @relation(fields: [gastoId], references: [id], onDelete: Cascade)
  gusto     Gusto?   @relation(fields: [gustoId], references: [id], onDelete: Cascade)

  @@map("items")
}

model Evento {
  id             String   @id @default(uuid())
  nombre         String
  cantidad       Float
  isNotificacion Boolean  @default(false)
  fecha          DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  usuarioId      String
  usuario        Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("eventos")
}

model Deseo {
  id        String      @id @default(uuid())
  cantidad  Float
  aportado  Float       @default(0)
  comprado  Boolean     @default(false)
  fecha     DateTime    @default(now())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  usuarioId String
  usuario   Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  items     DeseoItem[]

  @@map("deseos")
}

model DeseoItem {
  id                 String    @id @default(uuid())
  nombre             String
  precio             Float
  foto               String?
  tienda             String?
  urlReferencia      String?
  moneda             String?
  prioridad          String    @default("media")
  fecha              DateTime  @default(now())
  posibleCompraFecha DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deseoId            String
  deseo              Deseo     @relation(fields: [deseoId], references: [id], onDelete: Cascade)

  @@map("deseos_items")
}

model HistorialMensual {
  id            String   @id @default(uuid())
  mesReferencia String
  etiqueta      String
  gastos        Json
  gustos        Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("historiales_mensuales")
}

model Proyeccion {
  id          String   @id @default(uuid())
  salarioMeta Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("proyecciones")
}

model MetaAhorro {
  id             String   @id @default(uuid())
  nombre         String
  categoria      String
  montoObjetivo  Float
  montoActual    Float
  aporteMensual  Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  usuarioId      String
  usuario        Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("metas_ahorro")
}

model Notificacion {
  id          String   @id @default(uuid())
  titulo      String
  descripcion String?
  fecha       DateTime
  leida       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("notificaciones")
}

model Sesion {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  rememberMe Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sesiones")
}
